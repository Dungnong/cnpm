@startuml ERD_So_Do_Thuc_The
title Sơ đồ thực thể (Entity Relationship Diagram)

entity "tblManager" as Manager {
    * managerId : INT <<PK>>
    --
    username : VARCHAR(50)
    password : VARCHAR(255)
    fullName : VARCHAR(100)
    phone : VARCHAR(20)
}

entity "tblPitch" as Pitch {
    * pitchId : INT <<PK>>
    --
    pitchName : VARCHAR(100)
    pitchType : VARCHAR(50)
    description : TEXT
    pricePerHour : DECIMAL(10,2)
}

entity "tblClient" as Client {
    * clientId : INT <<PK>>
    --
    fullName : VARCHAR(100)
    phone : VARCHAR(20)
    email : VARCHAR(100)
}

entity "tblService" as Service {
    * serviceId : INT <<PK>>
    --
    serviceName : VARCHAR(100)
    unit : VARCHAR(30)
    price : DECIMAL(10,2)
}

entity "tblBookedPitch" as BookedPitch {
    * bookId : INT <<PK>>
    --
    clientId : INT <<FK>>
    pitchId : INT <<FK>>
    startTime : DATETIME
    endTime : DATETIME
    totalHours : DECIMAL(5,2)
    status : VARCHAR(20)
}

entity "tblBill" as Bill {
    * billId : INT <<PK>>
    --
    bookId : INT <<FK>>
    managerId : INT <<FK>>
    paymentDate : DATETIME
    totalAmount : DECIMAL(10,2)
    note : TEXT
}

entity "tblBillService" as BillService {
    * billServiceId : INT <<PK>>
    --
    billId : INT <<FK>>
    serviceId : INT <<FK>>
    quantity : INT
    subTotal : DECIMAL(10,2)
}

Client ||--o{ BookedPitch : "đặt sân"
Pitch ||--o{ BookedPitch : "được đặt"
BookedPitch ||--|| Bill : "thanh toán"
Manager ||--o{ Bill : "xác nhận"
Bill ||--o{ BillService : "bao gồm"
Service ||--o{ BillService : "được sử dụng"

@enduml
